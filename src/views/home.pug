block content
    .home
        .home__wrapper 
            .home__hero__wrapper
                canvas.home__canvas__particles 
                .home__title__wrapper
                    h1.home__title 
                        span Traces
                        img(src="/img/logo-hero.svg", alt="Traces by Aides", srcset="")
