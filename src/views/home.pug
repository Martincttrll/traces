                //- img.text__shape(src="/img/shape3.svg", alt="text container", srcset="")
                .home__carousel__wrapper 
                    img.carousel__item(src="/img/texture1.png", alt="carousel placeholder")
                    img.carousel__item(src="/img/texture2.png", alt="carousel placeholder")
                    img.carousel__item(src="/img/texture3.png", alt="carousel placeholder")
